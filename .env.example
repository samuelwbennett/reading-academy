# Reading Academy — environment variables
#
# Copy to .env.local for local dev. In Vercel, set the same variables in
# Project → Settings → Environment Variables for Preview and Production.
#
# Vite exposes ONLY variables prefixed VITE_ to the browser. The rest stay
# server-side and are read by Vercel functions in api/*.js.

# ---- Browser (Vite SPA) -------------------------------------------------
# Same Supabase project as math-facts and reading-facts (ref dtkrnyberbpfdmikpdnw).
VITE_SUPABASE_URL=https://dtkrnyberbpfdmikpdnw.supabase.co
VITE_SUPABASE_ANON_KEY=

# ---- Server (Vercel functions: api/snapshot.js, api/mastery.js) ---------
# These are read inside the serverless functions to do RLS-bypassing reads
# against student_app_accounts. NEVER expose the service-role key in VITE_*.
SUPABASE_URL=https://dtkrnyberbpfdmikpdnw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Note: the app slug in the learning_apps table is `reading_academy`
# (underscore), not `reading-academy`. The hyphenated form is only the
# Vercel subdomain. The api/*.js files have APP_SLUG hardcoded.
