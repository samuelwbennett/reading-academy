# Reading Academy — environment variables
#
# Copy to .env.local for local dev. In Vercel, set the same variables in
# Project → Settings → Environment Variables for Preview and Production.
#
# Vite exposes ONLY variables prefixed VITE_ to the browser. The rest stay
# server-side and are read by Vercel functions in api/*.js.

# ---- Browser (Vite SPA) -------------------------------------------------
# Same Supabase project as math-facts and reading-facts (ref dtkrnyberbpfdmikpdnw).
VITE_SUPABASE_URL=https://dtkrnyberbpfdmikpdnw.supabase.co
VITE_SUPABASE_ANON_KEY=

# ---- Server (Vercel functions: api/snapshot.js, api/mastery.js,
#               api/recap.js, api/insight-recommendation.js) -------------
# These are read inside the serverless functions. NEVER expose any of
# them in VITE_* — they bypass RLS and would leak if shipped to the
# browser bundle.
SUPABASE_URL=https://dtkrnyberbpfdmikpdnw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ---- AI features (M8) ---------------------------------------------------
# Required for /api/recap (weekly LLM summaries) and
# /api/insight-recommendation (per-insight teacher tips). Without it,
# both endpoints fall back to deterministic templates so they never
# 500 — but the `llmUsed` flag in their responses will be false and
# the dashboard chip will read "template" instead of "AI".
ANTHROPIC_API_KEY=

# ---- Role allowlists (M12-B) -------------------------------------------
# Comma-separated email lists. Used by /api/provision-self to decide
# the product role on first sign-in. Server-side only — clients can
# never read or set their own role.
#
# Order of precedence:
#   1. ADMIN_EMAIL_ALLOWLIST   → role = 'admin'
#   2. TEACHER_EMAIL_ALLOWLIST → role = 'teacher' (also creates a `teachers` row)
#   3. otherwise               → role = 'student' (status: awaiting_assignment)
#
# Replace with org-invite flow once that lands (M13+).
ADMIN_EMAIL_ALLOWLIST=
TEACHER_EMAIL_ALLOWLIST=

# ---- Azure Speech (M15) ------------------------------------------------
# Required for /api/azure-speech-token. Without these, the SPA falls
# back to Web Speech API (Chrome/Safari/Edge) — slightly lower
# pronunciation accuracy but still works. Both server-only.
#
# Provision in Azure Portal: create a Speech resource, copy KEY1 +
# region. See docs/pilot/azure-speech-setup.md.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

# Optional: explicit production base URL for invite/recap links.
# Default infers from request host header.
PUBLIC_SITE_URL=

# Note: the app slug in the learning_apps table is `reading_academy`
# (underscore), not `reading-academy`. The hyphenated form is only the
# Vercel subdomain. The api/*.js files have APP_SLUG hardcoded.
